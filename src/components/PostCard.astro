---
import TagBadge from './TagBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-zinc-800 rounded-xl p-5 hover:border-zinc-600 transition-colors">
  <a href={`${import.meta.env.BASE_URL}${post.slug}`} class="block">
    <div class="flex flex-wrap gap-1.5 mb-2">
      {tags.map((tag) => <TagBadge tag={tag} />)}
    </div>
    <h2 class="text-lg font-semibold mb-1.5 group-hover:text-indigo-300 transition-colors">
      {title}
    </h2>
    <p class="text-sm text-zinc-400 line-clamp-2 mb-3">{description}</p>
    <time class="text-xs text-zinc-500" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
  </a>
</article>
